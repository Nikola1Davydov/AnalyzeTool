<Project>

  <!--
    Shared MSBuild settings for AnalyseTool.Sdk and every C# extension that targets it.
    Import near the top of an extension .csproj:

        <Import Project="..\..\AnalyseTool.Sdk\build\AnalyseTool.Extension.props" />

    CRITICAL: Revit API (and, in extension projects, the SDK itself) are referenced compile-only
    (PrivateAssets=all + ExcludeAssets=runtime / <Private>false</Private>) so the build output does
    NOT carry duplicate copies. The host owns those assemblies; the extension's AssemblyLoadContext
    shares the host's, which is what keeps type identity intact (IRevitTask, UIApplication, JToken).
  -->

    <PropertyGroup>
        <Configurations>
            Debug R25;
            Debug R26;
            Debug R27;
            Release R25;
            Release R26;
            Release R27;
        </Configurations>
        <PlatformTarget>x64</PlatformTarget>
    </PropertyGroup>
    
    <PropertyGroup>
        <PlatformTarget>x64</PlatformTarget>
    </PropertyGroup>

  <PropertyGroup Condition="$(Configuration.Contains('R25'))">
    <RevitVersion>2025</RevitVersion>
    <TargetFramework>net8.0-windows</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Condition="$(Configuration.Contains('R26'))">
    <RevitVersion>2026</RevitVersion>
    <TargetFramework>net8.0-windows</TargetFramework>
  </PropertyGroup>

    <PropertyGroup Condition="$(Configuration.Contains('R27'))">
        <RevitVersion>2027</RevitVersion>
        <TargetFramework>net10.0-windows</TargetFramework>
    </PropertyGroup>

  <!-- The Revit API version floats with the configuration ($(RevitVersion).*), so it cannot live in a
       central Directory.Packages.props. This file is consumed in BOTH worlds: the AnalyseTool repo
       (Central Package Management ON — plain Version would be error NU1008, so VersionOverride) and
       external extension authors via the NuGet package (CPM OFF — VersionOverride would be ignored
       with NU1009, so plain Version). The conditional metadata picks the right attribute per world. -->
  <ItemGroup>
    <PackageReference Include="Nice3point.Revit.Api.RevitAPI">
      <Version Condition="'$(ManagePackageVersionsCentrally)' != 'true'">$(RevitVersion).*</Version>
      <VersionOverride Condition="'$(ManagePackageVersionsCentrally)' == 'true'">$(RevitVersion).*</VersionOverride>
      <PrivateAssets>all</PrivateAssets>
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI">
      <Version Condition="'$(ManagePackageVersionsCentrally)' != 'true'">$(RevitVersion).*</Version>
      <VersionOverride Condition="'$(ManagePackageVersionsCentrally)' == 'true'">$(RevitVersion).*</VersionOverride>
      <PrivateAssets>all</PrivateAssets>
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
