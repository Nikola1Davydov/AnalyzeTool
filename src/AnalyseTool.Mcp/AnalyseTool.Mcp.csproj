<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Out-of-process MCP server. The AI client (Claude Desktop, etc.) spawns this exe and talks MCP
    over stdio; the exe forwards each tool call over a localhost WebSocket to the in-Revit bridge
    (McpBridgeServer) which reaches the SAME CommandDispatcher. So every built-in AND user-extension
    command is exposed to AI automatically (discovered live via the bridge's "list" message).

    No Revit/SDK references on purpose: this process never loads the Revit API. It only speaks two
    JSON protocols (MCP stdio <-> our tiny bridge envelope). net8.0 (not -windows): no UI.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>AnalyseTool.Mcp</AssemblyName>
    <RootNamespace>AnalyseTool.Mcp</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <PropertyGroup Condition="$(Configuration.Contains('Release'))">
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>

  <ItemGroup>
    <!-- Wire contract shared with the in-Revit bridge (AnalyseTool.Mcp.Bridge) — compiled into both
         sides so field renames break the build, not the runtime. A linked file, NOT a ProjectReference:
         the bridge is net8/net10-windows and drags Core/Revit deps this exe must never load. -->
    <Compile Include="..\AnalyseTool.Mcp.Bridge\McpWire.cs" Link="McpWire.cs" />
  </ItemGroup>

</Project>
